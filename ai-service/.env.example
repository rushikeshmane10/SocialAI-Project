# --- LLM (choose one) ---
# Default in code is groq; set GROQ_API_KEY for local dev.
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7

# Or OpenAI for chat:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.7
# OPENAI_CHAT_TIMEOUT_SECONDS=60

# Or local Ollama (no OpenAI key required for chat when LLM_PROVIDER=ollama)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_TEMPERATURE=0.7

# --- Image Generation Provider ---
IMAGE_PROVIDER=pollinations
# options: pollinations | gemini | dalle
GEMINI_API_KEY=

# --- Images (legacy OpenAI path; currently inactive in main generation route) ---
# IMAGE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_IMAGE_MODEL=dall-e-3
# OPENAI_IMAGE_SIZE=1024x1024
# OPENAI_IMAGE_TIMEOUT_SECONDS=120

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Node callback (for async generation completion) ---
NODE_CALLBACK_BASE_URL=http://127.0.0.1:3001
GENERATE_CALLBACK_PATH=/ai/callback/generate-complete
GENERATE_CALLBACK_TIMEOUT_SECONDS=8
GENERATE_CALLBACK_MAX_ATTEMPTS=3
GENERATE_CALLBACK_RETRY_BASE_SECONDS=1.0
# Per /generate-async tone (tweet + visual prompt). Raise if Ollama is slow (default 600s).
# GENERATE_ASYNC_TONE_TIMEOUT_SECONDS=900
