PORT=3001
NODE_ENV=development

# Supabase (Postgres only): copy the connection string from the Supabase dashboard:
# Project Settings → Database → Connection string → URI (use "Session" or "Direct" for the backend).
# Put the real value in backend/.env (never commit .env — it is gitignored at repo root).
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# When DATABASE_URL is set, DB routes and migrations are enabled.
# RUN_MIGRATIONS_ON_START=true
#
# If you see SequelizeHostNotFoundError / ENOTFOUND for db.*.supabase.co:
# - Copy the URI again from Supabase → Project Settings → Database (host must match your project).
# - On Windows, the direct host can be IPv6-only; if ENOTFOUND or ENETUNREACH persists, use the pooler URI from the same page
#   (aws-0-<region>.pooler.supabase.com) — region must match your project.
# - Un-pause the project if it was paused; free tier projects pause after inactivity.
# - For local tweet-only testing, comment out DATABASE_URL so the server starts without Postgres.

AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_TIMEOUT_MS=25000
AI_SERVICE_GENERATE_TIMEOUT_MS=120000
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace-this-in-production
SOCKET_BYPASS_JWT=false
# SOCKET_BYPASS_SECRET=shared-dev-secret

# Twitter/X OAuth 1.0a (user context) — required for POST /post/tweet
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Composio OAuth (Twitter / LinkedIn) — required for /connections/* routes
COMPOSIO_API_KEY=
# Optional: LinkedIn post image compression before Composio (decoded JPEG byte cap / max edge / initial quality)
# COMPOSIO_LINKEDIN_IMAGE_MAX_BYTES=900000
# COMPOSIO_LINKEDIN_IMAGE_MAX_EDGE=1600
# COMPOSIO_LINKEDIN_IMAGE_JPEG_QUALITY_START=82
